maintainer="Luís Fonseca <luis@lhf.pt>"
pkgname=lhf
pkgver=1.0.0
pkgrel=0
upstream_author="luishfonseca"
category="misc"
pkgdesc="Personal scripts for my remarkable"
url="https://github.com/luishfonseca/rm-scripts"
arch="armv7"
license="Unlicense"
depends="mount-utils remarkable-os>=3.24"
source="
patch-rmfakecloud-proxy.sh
"
options="!check !fhs !tracedeps"

package() {
    install -Dm744 patch-rmfakecloud-proxy.sh "$pkgdir/home/root/.vellum/bin/patch-rmfakecloud-proxy"
}

postinstall() {
    /home/root/.vellum/bin/mount-rw
    /home/root/.vellum/bin/patch-rmfakecloud-proxy install
    /home/root/.vellum/bin/mount-restore
}

postupgrade() {
    /home/root/.vellum/bin/mount-rw
    /home/root/.vellum/bin/patch-rmfakecloud-proxy install
    /home/root/.vellum/bin/mount-restore
}

postosupgrade() {
    /home/root/.vellum/bin/patch-rmfakecloud-proxy install
}

predeinstall() {
    /home/root/.vellum/bin/mount-rw
    /home/root/.vellum/bin/patch-rmfakecloud-proxy remove
    /home/root/.vellum/bin/mount-restore
}

